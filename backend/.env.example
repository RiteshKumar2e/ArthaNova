# ArthaNova Backend — Environment Variables
# Copy this file to .env and fill in your values

# Application
APP_NAME=ArthaNova
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/arthanova
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/arthanova

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@arthanova.in

# External APIs
NSE_BASE_URL=https://www.nseindia.com
BSE_BASE_URL=https://www.bseindia.com

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Sentry (optional)
SENTRY_DSN=
