# ArthaNova Backend — Environment Variables
# DO NOT COMMIT THIS FILE

APP_NAME=ArthaNova
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development
SECRET_KEY=arthanova-super-secret-key-development-32chars!!
ALLOWED_ORIGINS='["http://localhost:5173", "http://localhost:3000"]'

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/arthanova
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/arthanova

JWT_SECRET_KEY=arthanova-jwt-secret-key-development-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

REDIS_URL=redis://localhost:6379/0

OPENAI_API_KEY=sk-proj-dummy-key-replace-with-real-key
OPENAI_MODEL=gpt-4o

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=arthanova.alerts@gmail.com
SMTP_PASSWORD=your-smtp-password
FROM_EMAIL=noreply@arthanova.in

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
SENTRY_DSN=
